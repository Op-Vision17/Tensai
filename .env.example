# =============================================================================
# Tensai — copy to .env and set your values
# =============================================================================

# --- Chat (need one: GROQ_API_KEY or OPENAI_API_KEY) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=llama-3.3-70b-versatile

# OPENAI_API_KEY=
# CHAT_MODEL=gpt-4o

# --- Embeddings (need one: JINA_API_KEY or OPENAI_API_KEY) ---
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024

# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=tensai-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.eegptyeaqftzzyypxmjn.supabase.co:5432/postgres

# --- Auth: JWT ---
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
JWT_REFRESH_EXPIRE_DAYS=30

# --- Auth: SMTP (for OTP email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tensai.local
OTP_EXPIRE_MINUTES=10
EMAIL_TIMEZONE=Asia/Kolkata

# --- Optional: graph tuning ---
# DEFAULT_TOP_K=5
# MAX_TOP_K=15
# CONFIDENCE_THRESHOLD=0.7
# MAX_RETRIES=2
